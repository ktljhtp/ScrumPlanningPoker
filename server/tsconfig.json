{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "dist",
    "rootDir": "."
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["app.js", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
